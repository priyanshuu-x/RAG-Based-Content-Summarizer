# Copy this file to .streamlit/secrets.toml and fill in your real key.
# NEVER commit the real secrets.toml to git — add it to .gitignore.
#
# Locally: place this at .streamlit/secrets.toml in your project root.
# On Streamlit Community Cloud: paste the same content into
# "App settings" -> "Secrets" in the dashboard instead of a file.

GROQ_API_KEY = "your-groq-api-key-here"
